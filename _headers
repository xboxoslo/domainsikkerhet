/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Statiske assets med versjon-query (?v=...) er immutable
/_assets/*
  Cache-Control: public, max-age=31536000, immutable

# Sider som oppdateres automatisk hver dag/uke — kortere cache så nye AI-poster
# og trender vises raskt for besøkende.
/blogg/
  Cache-Control: public, max-age=60, must-revalidate

/blogg/index.html
  Cache-Control: public, max-age=60, must-revalidate

/trender/
  Cache-Control: public, max-age=60, must-revalidate

/trender/index.html
  Cache-Control: public, max-age=60, must-revalidate

/sitemap.xml
  Cache-Control: public, max-age=60, must-revalidate

/*
  Cache-Control: public, max-age=300, must-revalidate
